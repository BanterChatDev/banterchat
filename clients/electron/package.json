{
  "name": "banterchat-desktop",
  "version": "0.1.0",
  "description": "Banter desktop client",
  "author": "Banter",
  "main": "src/main.js",
  "productName": "banterchat",
  "scripts": {
    "build:ui:js": "esbuild src/ui/pages/app.jsx --bundle --jsx=automatic --target=chrome120 --format=iife --outfile=src/ui/dist/app.js",
    "build:ui:css": "tailwindcss -c tailwind.config.js -i src/ui/styles/tailwind.css -o src/ui/dist/ui.css --minify",
    "build:ui": "npm run build:ui:js && npm run build:ui:css",
    "watch:ui:js": "esbuild src/ui/pages/app.jsx --bundle --jsx=automatic --target=chrome120 --format=iife --outfile=src/ui/dist/app.js --watch",
    "watch:ui:css": "tailwindcss -c tailwind.config.js -i src/ui/styles/tailwind.css -o src/ui/dist/ui.css --watch",
    "start": "npm run build:ui && electron .",
    "start:dev": "BANTER_URL=http://localhost:3030 npm run build:ui && electron .",
    "build": "npm run build:ui && electron-builder",
    "build:win": "npm run build:ui && electron-builder --win",
    "build:mac": "npm run build:ui && electron-builder --mac",
    "build:linux": "npm run build:ui && electron-builder --linux"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "tailwindcss": "^3.4.14"
  },
  "build": {
    "appId": "org.banterchat.desktop",
    "productName": "banterchat",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!src/ui/components/**/*",
      "!src/ui/pages/**/*",
      "!src/ui/styles/**/*",
      "!src/ui/lib/**/*"
    ],
    "extraResources": [],
    "extraFiles": [],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.social-networking",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "category": "Network",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}