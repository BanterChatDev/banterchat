HTTP_ADDR=:3030
DOMAIN=example.com
SECURE_COOKIES=true
MAX_BODY_SIZE=10M

# generated by setup.sh on first run
MASTER_KEY=

DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=banter
# generated by setup.sh on first run
DB_PASSWORD=
DB_NAME=banter
DB_SSLMODE=disable

# leave blank to disable voice and video
LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxxxxx

# leave blank to disable the GIF picker
TENOR_API_KEY=AIzaSyXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# comma-separated extra origins for the websocket if your reverse proxy uses a different host
WS_EXTRA_ORIGINS=

# shown in the warning message sent to users
TERMS_URL=https://example.com/terms
