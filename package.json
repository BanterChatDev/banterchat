{
  "name": "thugchat",
  "scripts": {
    "build:js": "esbuild assets/src/js/index.jsx --bundle --outfile=assets/public/js/app.bundle.js --jsx=automatic --minify --define:process.env.NODE_ENV=\\\"production\\\"",
    "build:css": "tailwindcss -i assets/src/css/main.css -o assets/public/css/app.bundle.css --minify",
    "build": "npm run build:js && npm run build:css",
    "watch:js": "esbuild assets/src/js/index.jsx --bundle --outfile=assets/public/js/app.bundle.js --jsx=automatic --watch",
    "watch:css": "tailwindcss -i assets/src/css/main.css -o assets/public/css/app.bundle.css --watch",
    "dev": "npm run watch:js & npm run watch:css"
  },
  "dependencies": {
    "livekit-client": "^2.18.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-rnd": "^10.5.3",
    "use-stick-to-bottom": "^1.0.46"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "tailwindcss": "^3.4.0"
  }
}
